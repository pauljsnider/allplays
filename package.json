{
  "name": "allplays",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "test": "vitest run tests/unit",
    "test:unit": "vitest run tests/unit",
    "test:unit:ci": "vitest run tests/unit --reporter=dot",
    "test:coverage-map": "node scripts/report-test-coverage-map.mjs --check",
    "test:functions:notifications": "npm run test:notifications --prefix functions",
    "test:smoke": "playwright test --config=playwright.smoke.config.js",
    "test:smoke:team-fallback": "playwright test tests/smoke/team-fallback-regressions.spec.js --config=playwright.smoke.config.js --reporter=line",
    "ci:firebase-rules": "node scripts/validate-firebase-rules-ci.mjs",
    "stage:pages": "node scripts/stage-pages-bundle.mjs",
    "app:build-help-index": "node scripts/build-app-help-knowledge-index.mjs",
    "app:check-bundle-size": "node scripts/check-app-bundle-size.mjs",
    "serve:firebase": "firebase emulators:start --only hosting --project demo-allplays",
    "app:dev": "npm --prefix apps/app run dev",
    "app:build": "npm --prefix apps/app run build && node scripts/verify-app-bundle-visualizer.mjs",
    "app:preview": "npm --prefix apps/app run preview",
    "mobile:serve": "npm run app:dev",
    "mobile:sync": "npm run app:build && npx cap sync",
    "mobile:build:ios": "npm run mobile:sync && DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer xcodebuild -project ios/App/App.xcodeproj -scheme App -configuration Debug -sdk iphonesimulator -destination 'generic/platform=iOS Simulator' CODE_SIGNING_ALLOWED=NO build",
    "mobile:build:android": "npm run mobile:sync && cd android && JAVA_HOME=\"/Applications/Android Studio.app/Contents/jbr/Contents/Home\" ./gradlew :app:assembleDebug",
    "mobile:open:ios": "DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer npx cap open ios",
    "mobile:open:android": "npx cap open android",
    "mobile:run:ios": "npm run app:build && DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer npx cap run ios",
    "mobile:run:android": "npm run app:build && JAVA_HOME=\"/Applications/Android Studio.app/Contents/jbr/Contents/Home\" npx cap run android"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@sentry/browser": "^10.63.0",
    "@testing-library/react": "^16.3.2",
    "firebase-tools": "^15.22.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor-firebase/messaging": "^8.3.0",
    "@capacitor-firebase/performance": "^8.3.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-speech-recognition": "^8.1.9",
    "firebase": "^12.15.0",
    "html-to-image": "^1.11.13",
    "jsdom": "^29.1.1",
    "web-vitals": "^5.3.0"
  }
}
